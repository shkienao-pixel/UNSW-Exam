# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=artifacts

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Data directory (ChromaDB, local files) ────────────────────────────────────
DATA_DIR=./data

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
API_URL=https://api.exammaster.tech

# CORS: allow requests from the frontend domain
CORS_ORIGINS=https://exammaster.tech,https://www.exammaster.tech

# Admin secret — use a long random string (openssl rand -hex 32)
ADMIN_SECRET=change-this-to-a-random-secret
